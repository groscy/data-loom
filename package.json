{
  "name": "data-loom",
  "version": "0.2.0",
  "private": true,
  "description": "Local dashboard for spec-driven development: a phased OpenSpec roadmap (WHAT) and an MCP topology (HOW).",
  "type": "module",
  "bin": {
    "data-loom": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node --watch dist/index.js",
    "bundle": "node scripts/build-exe.mjs --bundle-only",
    "package": "node scripts/build-exe.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/ws": "^8.5.12",
    "esbuild": "^0.24.0",
    "png-to-ico": "^2.1.8",
    "postject": "^1.0.0-alpha.6",
    "rcedit": "^4.0.1",
    "sharp": "^0.33.5",
    "typescript": "^5.6.2"
  }
}
