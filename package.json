{
  "name": "@lyric_dev/data-loom",
  "version": "0.9.1",
  "description": "Local dashboard for spec-driven development: a phased OpenSpec roadmap (WHAT) and an MCP topology (HOW).",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/groscy/data-loom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/groscy/data-loom.git"
  },
  "bugs": {
    "url": "https://github.com/groscy/data-loom/issues"
  },
  "keywords": [
    "openspec",
    "mcp",
    "dashboard",
    "roadmap",
    "spec-driven-development",
    "claude-code"
  ],
  "bin": {
    "data-loom": "dist/index.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node --watch dist/index.js",
    "prepublishOnly": "npm run build",
    "sync-global": "node scripts/sync-global.mjs",
    "postpublish": "npm run sync-global"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.2"
  }
}
